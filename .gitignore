# ==========================================
# 1. 忽略所有系统临时文件、Python 缓存等
# ==========================================
__pycache__/
*.pyc
.DS_Store

# ==========================================
# 2. 数据目录隔离区 (核心策略)
# ==========================================
# 忽略 Temp_data 目录下的【所有内容】
Data_Preprocessing/Temp_data/*

# (可选) 保留一个空的 .gitkeep 文件，让 Github 知道有这么个空文件夹存在
!Data_Preprocessing/Temp_data/.gitkeep

